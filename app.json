{
  "expo": {
    "name": "Gulpy",
    "slug": "Gulpy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/FullLogo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1628"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aaadrika-dwivedi.Gulpy",
      "icon": "./assets/FullLogo.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/FullLogo.png",
        "backgroundColor": "#0a1628"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.aaadrika_dwivedi.Gulpy"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "cd15e3d6-ea66-438d-94a0-65c0b24a4e53"
      }
    },
    "owner": "awwwdrika"
  }
}
