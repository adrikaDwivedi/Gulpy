{
  "expo": {
    "name": "Gulpy",
    "slug": "Gulpy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/FullLogo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1628"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aaadrika-dwivedi.Gulpy",
          "icon": "./assets/FullLogo.png"

    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/FullLogo.png",
        "backgroundColor": "#0a1628"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.aaadrika_dwivedi.Gulpy"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
